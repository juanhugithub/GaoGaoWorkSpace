#
# Gitee Release 发布配置
#
GITEE_TOKEN=your_gitee_personal_access_token
GITEE_OWNER=your-gitee-owner
GITEE_REPO=your-gitee-repo
GITEE_BRANCH=main
GITEE_UPDATE_JSON_PATH=update.json

#
# Tauri Updater 签名配置
# TAURI_SIGNING_PRIVATE_KEY 可以直接写密钥内容，也可以写本机私钥文件绝对路径。
#
TAURI_SIGNING_PRIVATE_KEY=C:/Users/Administrator/.tauri/personal-os.key
TAURI_SIGNING_PRIVATE_KEY_PASSWORD=
