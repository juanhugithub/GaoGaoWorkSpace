{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "个人高绩效工作台",
  "version": "1.0.330",
  "identifier": "com.juanhu.gaogaoworkspace",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "个人高绩效工作台",
        "width": 1680,
        "height": 1020,
        "minWidth": 1320,
        "minHeight": 820,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": "v1Compatible",
    "targets": [
      "nsis"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "offlineInstaller",
        "silent": true
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEMzQUU3REQxRUVCODg0MjUKUldRbGhManUwWDJ1dzF2RnJ1d1ViN1NMN3grckJlOEh6QitPb0FYemJGM0tUNDU4WWZqSS9yS0IK",
      "active": true,
      "endpoints": [
        "https://gitee.com/juanhu6/gao-gao-work-bench/raw/main/update.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
